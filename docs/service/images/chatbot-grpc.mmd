flowchart TD
    %% Định nghĩa các node
    User([Người dùng])
    NextJS[NextJS Frontend]
    Kong[Kong API Gateway]
    NestJS[NestJS Backend]
    AIPython[AI Python Service]
    LLM[Mô hình LLM]
    SQL[(SQL Database)]

    %% Định nghĩa luồng dữ liệu
    User -- Nhắn tin --> NextJS
    NextJS -- HTTP/REST --> Kong
    Kong --> NestJS
    NestJS -- Gọi AI --> AIPython
    AIPython <-- Giao tiếp --> LLM

    %% Lưu lịch sử
    AIPython -- Lưu lịch sử hội thoại --> SQL

    %% Style (Tùy chọn cho đẹp mắt)
    style User fill:#f9f,stroke:#333,stroke-width:2px
    style SQL fill:#f9a,stroke:#333,stroke-width:2px
    style AIPython fill:#bbf,stroke:#333,stroke-width:2px
